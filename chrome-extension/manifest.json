{
  "manifest_version": 3,
  "name": "Cerebro Triage",
  "version": "0.1.0",
  "description": "Drop broker emails into the side panel and watch Cerebro classify and route them. Links into the localhost Cerebro queue.",
  "minimum_chrome_version": "114",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open Cerebro Triage",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "permissions": ["sidePanel", "storage", "contextMenus", "scripting", "activeTab", "alarms"],
  "host_permissions": [
    "http://localhost:3000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["toast.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
